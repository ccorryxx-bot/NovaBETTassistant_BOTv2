let adminClicks = 0;

/* =========================
   INIT
========================= */

window.addEventListener("load", async () => {

  try {

    document.title = BASE_TITLE;

    if (!firebase.apps.length) {
      firebase.initializeApp(firebaseConfig);
    }

    db = firebase.firestore();

    setupKnowledgeSync();

    addMessage(
      "bot",
      "မင်္ဂလာပါ! NovaBETT AI Support မှ ကြိုဆိုပါသည်။"
    );

    console.log("NovaBETT Ready");

  } catch (err) {

    console.error(err);
    alert(err.message);
  }
});


/* =========================
   KNOWLEDGE BASE SYNC
========================= */

function setupKnowledgeSync() {

  if (!db) return;

  db.collection("settings")
    .doc("knowledge")
    .onSnapshot((snap) => {

      if (!snap.exists) return;

      const el = document.getElementById("knowledgeBase");

      if (el) {
        el.value = snap.data().content || "";
      }
    });
}


/* =========================
   CHAT
========================= */

function handleSend() {

  const input = document.getElementById("userInput");

  if (!input) return;

  const text = input.value.trim();

  if (!text) return;

  addMessage("user", text);

  input.value = "";

  fakeAIReply(text);
}


function quickSend(text) {

  const input = document.getElementById("userInput");

  if (!input) return;

  input.value = text;

  handleSend();
}


async function fakeAIReply(userText) {

  let kb = "";

  const kbBox = document.getElementById("knowledgeBase");

  if (kbBox) {
    kb = kbBox.value.toLowerCase();
  }

  let reply = "NovaBETT Support မှ ပြန်လည်ကူညီပေးနေပါသည်။";

  if (userText.includes("ငွေ")) {
    reply = "ငွေသွင်းခြင်းများကို KB ထဲရှိ Guide အတိုင်း ဆောင်ရွက်နိုင်ပါသည်။";
  }

  if (userText.includes("password")) {
    reply = "Password ပြောင်းရန် Profile > Security မှ ပြောင်းနိုင်ပါသည်။";
  }

  addMessage("bot", reply);

  await logChat(userText, reply);
}


function addMessage(type, text) {

  const chatbox = document.getElementById("chatbox");

  if (!chatbox) return;

  const msg = document.createElement("div");

  msg.className = `msg ${type}`;

  msg.innerHTML = `
    <div class="msg-bubble">
      ${escapeHTML(text)}
    </div>
  `;

  chatbox.appendChild(msg);

  scrollDown();
}


/* =========================
   ADMIN PANEL
========================= */

function openAdmin() {

  document.getElementById("adminPanel").classList.add("open");
  document.getElementById("overlay").classList.add("show");
}


function closeAdmin() {

  document.getElementById("adminPanel").classList.remove("open");
  document.getElementById("overlay").classList.remove("show");
}


function switchTab(tab) {

  document.querySelectorAll(".tab-btn")
    .forEach(el => el.classList.remove("active"));

  document.querySelectorAll(".tab-panel")
    .forEach(el => el.classList.remove("active"));

  document
    .getElementById(`tab-${tab}-btn`)
    .classList.add("active");

  document
    .getElementById(`tab-${tab}`)
    .classList.add("active");

  if (tab === "logs") {
    loadChatLogs();
  }
}


/* =========================
   PASSWORD
========================= */

function tryUnlockKB() {

  const pw = document.getElementById("kbPassword").value;

  if (pw === "NovaBETT") {

    kbUnlocked = true;

    document.getElementById("kb-gate").style.display = "none";

    document.getElementById("kb-content").style.display = "flex";

  } else {

    const err = document.getElementById("kbError");

    err.style.display = "block";

    document.getElementById("kb-gate-form")
      .style.animation = "shake .45s";

    setTimeout(() => {
      document.getElementById("kb-gate-form")
        .style.animation = "";
    }, 500);
  }
}


function lockKBAgain() {

  kbUnlocked = false;

  document.getElementById("kb-gate").style.display = "flex";

  document.getElementById("kb-content").style.display = "none";
}


function togglePwVisibility() {

  const input = document.getElementById("kbPassword");

  input.type =
    input.type === "password"
      ? "text"
      : "password";
}


/* =========================
   SAVE KB
========================= */

async function saveToCloud() {

  if (!db) {
    alert("Firebase Error");
    return;
  }

  const text =
    document.getElementById("knowledgeBase").value;

  const btn =
    document.getElementById("saveBtn");

  btn.disabled = true;

  btn.innerText = "Saving...";

  try {

    await db.collection("settings")
      .doc("knowledge")
      .set({
        content: text,
        updatedAt: new Date().toISOString()
      });

    btn.innerText = "Saved";

    setTimeout(() => {
      btn.innerHTML = `
        <svg><use href="#ico-upload"/></svg>
        Push to Cloud
      `;
      btn.disabled = false;
    }, 2000);

  } catch (err) {

    console.error(err);

    alert(err.message);

    btn.disabled = false;
  }
}


/* =========================
   LOGS
========================= */

async function logChat(user, bot) {

  try {

    if (!db) return;

    await db.collection("chatLogs").add({
      user,
      bot,
      timestamp: Date.now()
    });

  } catch (err) {

    console.error(err);
  }
}


async function loadChatLogs() {

  const box = document.getElementById("logBox");

  if (!box) return;

  box.innerHTML = "Loading...";

  try {

    const snap = await db.collection("chatLogs")
      .orderBy("timestamp", "desc")
      .limit(50)
      .get();

    if (snap.empty) {

      box.innerHTML = `
        <div class="log-empty">
          No chat logs found
        </div>
      `;

      return;
    }

    let html = "";

    snap.forEach(doc => {

      const d = doc.data();

      html += `
        <div class="log-item">
          <div><strong>User:</strong> ${escapeHTML(d.user || "")}</div>
          <div><strong>Bot:</strong> ${escapeHTML(d.bot || "")}</div>
        </div>
      `;
    });

    box.innerHTML = html;

  } catch (err) {

    console.error(err);

    box.innerHTML = "Error loading logs";
  }
}


/* =========================
   UTIL
========================= */

function scrollDown() {

  const box = document.getElementById("chatbox");

  if (!box) return;

  box.scrollTop = box.scrollHeight;
}


function secretClick() {

  adminClicks++;

  if (adminClicks >= 5) {

    openAdmin();

    adminClicks = 0;
  }
}


function escapeHTML(str) {

  return String(str)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
}
