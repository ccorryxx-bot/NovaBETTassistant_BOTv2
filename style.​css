*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;height:100dvh;overflow:hidden;}
body{
  display:flex;justify-content:center;align-items:stretch;
  background:#05040c;
  font-family:'Sora','Noto Sans Myanmar',system-ui,sans-serif;
  color:#fef9ee;-webkit-font-smoothing:antialiased;
}
.bg{position:fixed;inset:0;z-index:0;pointer-events:none;}
.bg-noise{
  position:absolute;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity:.55;
}
.bg-lines{
  position:absolute;inset:0;
  background-image:repeating-linear-gradient(-55deg,transparent,transparent 38px,rgba(228,172,40,.018) 38px,rgba(228,172,40,.018) 39px);
}
.bg-orb{position:absolute;border-radius:50%;filter:blur(90px);}
.bg-orb-1{width:400px;height:400px;top:-100px;left:-80px;background:rgba(228,172,40,.10);animation:oFloat1 16s ease-in-out infinite alternate;}
.bg-orb-2{width:300px;height:300px;bottom:-80px;right:-60px;background:rgba(180,120,20,.08);animation:oFloat2 20s ease-in-out infinite alternate;}
.bg-orb-3{width:220px;height:220px;top:50%;left:55%;background:rgba(255,200,60,.05);animation:oFloat3 24s ease-in-out infinite alternate;}
@keyframes oFloat1{0%{transform:translate(0,0) scale(1);}100%{transform:translate(25px,18px) scale(1.04);}}
@keyframes oFloat2{0%{transform:translate(0,0) scale(1);}100%{transform:translate(-18px,-25px) scale(1.03);}}
@keyframes oFloat3{0%{transform:translate(0,0);}100%{transform:translate(-12px,12px);}}
#adminPanel{
  position:fixed;top:0;right:0;height:100%;height:100dvh;
  width:min(380px,100%);z-index:999;display:flex;flex-direction:column;
  background:#08070f;border-left:1px solid rgba(228,172,40,.18);
  box-shadow:-24px 0 80px rgba(0,0,0,.85),inset 1px 0 0 rgba(228,172,40,.06);
  transform:translateX(100%);transition:transform .32s cubic-bezier(.4,0,.2,1);
}
#adminPanel.open{transform:translateX(0);}
#adminPanel::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(228,172,40,.7),rgba(255,220,80,.5),transparent);}
.overlay{display:none;position:fixed;inset:0;z-index:998;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);}
.overlay.show{display:block;}
.panel-hd{padding:22px 22px 16px;border-bottom:1px solid rgba(228,172,40,.10);flex-shrink:0;display:flex;align-items:flex-start;justify-content:space-between;}
.panel-brand{display:flex;align-items:center;gap:11px;}
.panel-logo{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(228,172,40,.22),rgba(180,120,20,.12));border:1px solid rgba(228,172,40,.28);color:#e4ac28;flex-shrink:0;}
.panel-logo svg{width:20px;height:20px;}
.panel-ttl{font-size:13px;font-weight:600;color:#f0c840;letter-spacing:-.01em;}
.panel-sub{font-size:9px;font-family:'DM Mono',monospace;color:rgba(228,172,40,.38);letter-spacing:.07em;text-transform:uppercase;margin-top:2px;}
.panel-sync{display:flex;align-items:center;gap:6px;margin-top:8px;}
.sync-dot{width:5px;height:5px;border-radius:50%;background:#34d399;box-shadow:0 0 7px #34d399;animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.6);opacity:.4;}}
.sync-txt{font-size:9px;font-family:'DM Mono',monospace;color:rgba(52,211,153,.55);letter-spacing:.07em;text-transform:uppercase;}
.panel-close{width:30px;height:30px;border-radius:8px;border:1px solid rgba(228,172,40,.14);background:rgba(228,172,40,.05);color:rgba(240,200,64,.5);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.18s ease;flex-shrink:0;}
.panel-close:hover{background:rgba(228,172,40,.12);border-color:rgba(228,172,40,.3);color:#f0c840;transform:rotate(90deg);}
.panel-close svg{width:14px;height:14px;}
.panel-tabs{display:flex;gap:4px;padding:10px 16px;flex-shrink:0;background:rgba(0,0,0,.3);}
.tab-btn{flex:1;padding:8px 6px;border-radius:8px;cursor:pointer;border:1px solid rgba(228,172,40,.08);background:rgba(228,172,40,.02);color:rgba(255,255,255,.25);font-size:9px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;font-family:'DM Mono',monospace;display:flex;align-items:center;justify-content:center;gap:5px;transition:.16s ease;}
.tab-btn svg{width:9px;height:9px;}
.tab-btn:hover{background:rgba(228,172,40,.07);color:rgba(240,200,64,.7);}
.tab-btn.active{background:rgba(228,172,40,.12);border-color:rgba(228,172,40,.30);color:#f0c840;}
.tab-panel{display:none;flex:1;flex-direction:column;gap:10px;padding:14px 16px 16px;min-height:0;overflow:hidden;}
.tab-panel.active{display:flex;}
.panel-lbl{font-size:9px;font-family:'DM Mono',monospace;color:rgba(228,172,40,.40);letter-spacing:.08em;text-transform:uppercase;flex-shrink:0;}
textarea{flex:1;width:100%;border-radius:10px;padding:12px 14px;resize:none;outline:none;background:rgba(228,172,40,.03);border:1px solid rgba(228,172,40,.12);color:#fde68a;font-size:12px;line-height:1.76;font-family:'Sora','Noto Sans Myanmar',sans-serif;transition:border-color .2s,box-shadow .2s;scrollbar-width:thin;scrollbar-color:rgba(228,172,40,.18) transparent;min-height:0;overflow-y:auto;-webkit-overflow-scrolling:touch;}
textarea:focus{border-color:rgba(228,172,40,.38);box-shadow:0 0 0 3px rgba(228,172,40,.07);}
textarea::-webkit-scrollbar{width:3px;}
textarea::-webkit-scrollbar-thumb{background:rgba(228,172,40,.2);border-radius:99px;}
#saveBtn{display:flex;align-items:center;justify-content:center;gap:8px;padding:11px;border-radius:10px;border:none;cursor:pointer;font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;font-family:'DM Mono',monospace;background:linear-gradient(135deg,rgba(228,172,40,.20),rgba(180,120,20,.14));border:1px solid rgba(228,172,40,.28);color:#f0c840;box-shadow:0 0 20px rgba(228,172,40,.08);transition:.2s ease;flex-shrink:0;}
#saveBtn svg{width:11px;height:11px;}
#saveBtn:hover{filter:brightness(1.16);transform:translateY(-1px);box-shadow:0 4px 20px rgba(228,172,40,.18);}
#saveBtn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}
#saveBtn.saved{background:linear-gradient(135deg,rgba(5,150,105,.18),rgba(52,211,153,.10));border-color:rgba(52,211,153,.3);color:#6ee7b7;}
.kb-gate-icon{width:56px;height:56px;border-radius:16px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(228,172,40,.14),rgba(180,120,20,.06));border:1px solid rgba(228,172,40,.24);color:#e4ac28;box-shadow:0 0 28px rgba(228,172,40,.12);animation:lockPulse 2.4s ease-in-out infinite;}
@keyframes lockPulse{0%,100%{box-shadow:0 0 28px rgba(228,172,40,.12);}50%{box-shadow:0 0 44px rgba(228,172,40,.26);}}
.kb-gate-icon svg{width:26px;height:26px;}
.kb-gate-title{font-size:13px;font-weight:600;color:#f0c840;letter-spacing:-.01em;text-align:center;}
.kb-gate-sub{font-size:10px;font-family:'DM Mono',monospace;color:rgba(228,172,40,.38);letter-spacing:.05em;text-align:center;}
.kb-gate-form{display:flex;flex-direction:column;gap:10px;width:100%;}
.kb-pw-wrap{position:relative;border-bottom:2px solid rgba(228,172,40,.22);transition:border-color .25s;}
.kb-pw-wrap:focus-within{border-color:rgba(228,172,40,.65);}
.kb-pw-wrap::after{content:'';position:absolute;bottom:-2px;left:0;right:100%;height:2px;background:#e4ac28;box-shadow:0 0 8px rgba(228,172,40,.5);transition:right .35s ease;}
.kb-pw-wrap:focus-within::after{right:0;}
#kbPassword{width:100%;padding:10px 36px 10px 4px;border:none;outline:none;background:transparent;font-size:15px;color:#fef9ee;letter-spacing:.12em;text-align:center;caret-color:#e4ac28;font-family:'DM Mono',monospace;}
#kbPassword::placeholder{color:rgba(255,255,255,.20);letter-spacing:.04em;font-size:13px;}
.kb-toggle-pw{position:absolute;right:4px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(228,172,40,.40);padding:4px;transition:.16s ease;}
.kb-toggle-pw:hover{color:#e4ac28;}
.kb-toggle-pw svg{width:14px;height:14px;}
#kbUnlockBtn{display:flex;align-items:center;justify-content:center;gap:8px;padding:12px;border-radius:10px;border:none;cursor:pointer;font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;font-family:'DM Mono',monospace;background:linear-gradient(135deg,rgba(228,172,40,.22),rgba(180,120,20,.16));border:1px solid rgba(228,172,40,.32);color:#f0c840;box-shadow:0 0 20px rgba(228,172,40,.10);transition:.2s ease;}
#kbUnlockBtn svg{width:11px;height:11px;}
#kbUnlockBtn:hover{filter:brightness(1.18);transform:translateY(-1px);box-shadow:0 4px 22px rgba(228,172,40,.22);}
#kbUnlockBtn:active{transform:translateY(1px);}
.kb-error{font-size:10px;font-family:'DM Mono',monospace;text-align:center;color:#f87171;letter-spacing:.04em;opacity:0;transform:translateY(-4px);transition:.2s ease;pointer-events:none;}
.kb-error.show{opacity:1;transform:translateY(0);}
.kb-attempts{font-size:9px;font-family:'DM Mono',monospace;color:rgba(255,255,255,.18);text-align:center;}
.kb-content{display:none;flex:1;flex-direction:column;gap:10px;min-height:0;overflow:hidden;}
.kb-content.unlocked{display:flex;}
.kb-unlocked-bar{display:flex;align-items:center;gap:6px;padding:7px 10px;border-radius:8px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.14);flex-shrink:0;}
.kb-unlocked-bar svg{width:11px;height:11px;color:#34d399;}
.kb-unlocked-txt{font-size:9px;font-family:'DM Mono',monospace;color:rgba(52,211,153,.70);letter-spacing:.06em;text-transform:uppercase;flex:1;}
.kb-lock-btn{background:none;border:none;cursor:pointer;color:rgba(52,211,153,.45);font-size:9px;font-family:'DM Mono',monospace;letter-spacing:.04em;transition:.15s ease;text-transform:uppercase;}
.kb-lock-btn:hover{color:#f87171;}
.log-box{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;display:flex;flex-direction:column;gap:7px;min-height:0;scrollbar-width:none;}
.log-box::-webkit-scrollbar{display:none;}
.log-card{background:rgba(228,172,40,.03);border:1px solid rgba(228,172,40,.08);border-left:2px solid rgba(228,172,40,.25);border-radius:9px;padding:10px 12px;transition:.18s ease;}
.log-card:hover{border-color:rgba(228,172,40,.18);border-left-color:rgba(240,200,64,.5);background:rgba(228,172,40,.06);}
.log-q{font-size:10px;color:#f0c840;font-weight:600;margin-bottom:4px;line-height:1.4;}
.log-a{font-size:10px;color:rgba(255,255,255,.30);line-height:1.55;}
.log-t{font-size:9px;color:rgba(228,172,40,.28);margin-top:5px;font-family:'DM Mono',monospace;}
.log-empty{font-size:11px;color:rgba(255,255,255,.16);text-align:center;margin-top:20px;font-family:'DM Mono',monospace;}
.shell{position:relative;z-index:1;width:100%;max-width:520px;display:flex;flex-direction:column;height:100%;height:100dvh;background:rgba(8,7,15,.88);backdrop-filter:blur(28px) saturate(140%);-webkit-backdrop-filter:blur(28px) saturate(140%);border-left:1px solid rgba(228,172,40,.07);border-right:1px solid rgba(228,172,40,.07);box-shadow:0 0 130px rgba(0,0,0,.9);overflow:hidden;}
.shell::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;z-index:20;pointer-events:none;background:linear-gradient(90deg,transparent 0%,rgba(228,172,40,.6) 20%,rgba(255,220,80,.9) 50%,rgba(228,172,40,.6) 80%,transparent 100%);box-shadow:0 0 12px rgba(228,172,40,.3);}
header{display:flex;align-items:center;gap:12px;padding:14px 18px;flex-shrink:0;border-bottom:1px solid rgba(228,172,40,.08);background:rgba(0,0,0,.50);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);}
.hd-logo{position:relative;width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:linear-gradient(145deg,rgba(228,172,40,.18),rgba(180,120,20,.09));border:1px solid rgba(228,172,40,.30);color:#e4ac28;box-shadow:0 0 16px rgba(228,172,40,.14),inset 0 1px 0 rgba(255,255,255,.05);cursor:pointer;flex-shrink:0;overflow:hidden;transition:.22s cubic-bezier(.34,1.56,.64,1);}
.hd-logo svg{width:22px;height:22px;}
.hd-logo:hover{transform:scale(1.07);box-shadow:0 0 26px rgba(228,172,40,.30);}
.hd-logo:active{transform:scale(.92);}
.hd-logo::after{content:'';position:absolute;inset:0;pointer-events:none;background:linear-gradient(115deg,transparent 38%,rgba(255,255,255,.07) 50%,transparent 62%);}
.hd-info{flex:1;display:flex;flex-direction:column;gap:4px;}
.hd-name{font-size:15px;font-weight:700;letter-spacing:-.02em;line-height:1;background:linear-gradient(90deg,#e4ac28 0%,#f7d060 30%,#fff8e0 55%,#f0c840 75%,#e4ac28 100%);background-size:280% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:goldFlow 5s linear infinite;}
@keyframes goldFlow{0%{background-position:0% center;}100%{background-position:280% center;}}
.hd-tagline{display:flex;align-items:center;gap:6px;}
.hd-tagline-dot{width:5px;height:5px;border-radius:50%;background:#34d399;box-shadow:0 0 6px #34d399;animation:pulse 2s ease-in-out infinite;}
.hd-tagline-txt{font-size:9px;font-family:'DM Mono',monospace;color:rgba(228,172,40,.52);letter-spacing:.08em;text-transform:uppercase;}
.hd-right{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.hd-stat{display:flex;flex-direction:column;align-items:flex-end;gap:2px;}
.hd-stat-num{display:flex;align-items:center;gap:5px;font-size:13px;font-weight:700;color:#f0c840;font-family:'DM Mono',monospace;}
.hd-stat-num svg{width:11px;height:11px;color:rgba(228,172,40,.55);}
.hd-stat-lbl{font-size:8px;color:rgba(255,255,255,.20);letter-spacing:.05em;text-transform:uppercase;}
.hd-admin-btn{width:34px;height:34px;border-radius:9px;border:1px solid rgba(228,172,40,.14);background:rgba(228,172,40,.06);color:rgba(228,172,40,.50);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.18s ease;}
.hd-admin-btn svg{width:14px;height:14px;}
.hd-admin-btn:hover{background:rgba(228,172,40,.13);border-color:rgba(228,172,40,.28);color:#f0c840;}
.chatbox{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;overscroll-behavior-y:contain;padding:20px 18px 14px;display:flex;flex-direction:column;gap:4px;touch-action:pan-y;min-height:0;}
.chatbox::-webkit-scrollbar{width:2px;}
.chatbox::-webkit-scrollbar-track{background:transparent;}
.chatbox::-webkit-scrollbar-thumb{background:rgba(228,172,40,.18);border-radius:99px;}
.bot-wrap{display:flex;flex-direction:column;gap:0;align-self:flex-start;max-width:90%;margin-bottom:12px;animation:botIn .26s cubic-bezier(.34,1.3,.64,1);}
@keyframes botIn{from{transform:translateY(10px) scale(.97);opacity:0;}to{transform:translateY(0) scale(1);opacity:1;}}
.bot-sender{display:flex;align-items:center;gap:8px;padding:0 2px 6px 2px;}
.bot-av{width:26px;height:26px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(228,172,40,.14),rgba(180,120,20,.06));border:1px solid rgba(228,172,40,.22);color:rgba(228,172,40,.8);}
.bot-av svg{width:16px;height:16px;}
.bot-sender-name{font-size:9.5px;font-family:'DM Mono',monospace;color:rgba(228,172,40,.42);letter-spacing:.06em;text-transform:uppercase;}
.bot-card{background:rgba(255,255,255,.026);border:1px solid rgba(228,172,40,.09);border-left:3px solid rgba(228,172,40,.35);border-radius:0 14px 14px 14px;padding:13px 16px;font-size:13.5px;line-height:1.76;color:rgba(254,249,238,.90);word-break:break-word;box-shadow:0 4px 24px rgba(0,0,0,.32),inset 0 1px 0 rgba(255,255,255,.02);}
.bot-card.typing::after{content:'▌';font-size:.82em;color:#e4ac28;animation:blink .75s step-end infinite;margin-left:2px;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}
.bot-footer{display:flex;align-items:center;gap:8px;padding:6px 2px 0;flex-wrap:wrap;}
.bot-ts{font-size:8.5px;color:rgba(255,255,255,.16);font-family:'DM Mono',monospace;}
.bot-model{font-size:8px;color:rgba(228,172,40,.25);font-family:'DM Mono',monospace;}
.rate-row{display:flex;align-items:center;gap:4px;margin-left:auto;}
.rate-btn{width:22px;height:22px;border-radius:6px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);color:rgba(255,255,255,.22);transition:.18s cubic-bezier(.34,1.56,.64,1);}
.rate-btn svg{width:10px;height:10px;}
.rate-btn:hover{transform:scale(1.2);}
.rate-btn.up-active{background:rgba(52,211,153,.10);border-color:rgba(52,211,153,.25);color:#34d399;}
.rate-btn.dn-active{background:rgba(239,68,68,.09);border-color:rgba(239,68,68,.22);color:#ef4444;}
.user-wrap{display:flex;flex-direction:column;align-items:flex-end;gap:5px;align-self:flex-end;max-width:78%;margin-bottom:12px;animation:userIn .24s cubic-bezier(.34,1.3,.64,1);}
@keyframes userIn{from{transform:translateX(12px) scale(.97);opacity:0;}to{transform:translateX(0) scale(1);opacity:1;}}
.user-bubble{padding:12px 16px;border-radius:14px 0 14px 14px;font-size:13.5px;line-height:1.76;color:#fff;word-break:break-word;background:linear-gradient(145deg,rgba(228,172,40,.26),rgba(180,120,20,.18));border:1px solid rgba(228,172,40,.28);border-top-right-radius:4px;box-shadow:0 4px 20px rgba(228,172,40,.10),inset 0 1px 0 rgba(255,255,255,.07);}
.user-meta{display:flex;align-items:center;gap:5px;padding-right:2px;}
.user-ts{font-size:8.5px;color:rgba(255,255,255,.18);font-family:'DM Mono',monospace;}
.user-tick{font-size:9.5px;color:rgba(255,255,255,.18);transition:color .35s;}
.user-tick.sent{color:#e4ac28;text-shadow:0 0 8px rgba(228,172,40,.55);}
.think-wrap{display:flex;flex-direction:column;gap:0;align-self:flex-start;margin-bottom:12px;animation:botIn .22s cubic-bezier(.34,1.56,.64,1);}
.think-sender{display:flex;align-items:center;gap:8px;padding:0 2px 6px 2px;}
.think-lbl{font-size:9px;font-family:'DM Mono',monospace;color:rgba(228,172,40,.35);letter-spacing:.07em;text-transform:uppercase;animation:breathe 1.5s ease-in-out infinite;}
@keyframes breathe{0%,100%{opacity:.35;}50%{opacity:.82;}}
.think-card{display:flex;gap:8px;align-items:center;padding:13px 18px;background:rgba(255,255,255,.026);border:1px solid rgba(228,172,40,.09);border-left:3px solid rgba(228,172,40,.25);border-radius:0 14px 14px 14px;box-shadow:0 4px 20px rgba(0,0,0,.28);}
.td{width:7px;height:7px;border-radius:50%;animation:tdJ 1.2s ease-in-out infinite;}
.td:nth-child(1){background:#e4ac28;box-shadow:0 0 6px #e4ac28;}
.td:nth-child(2){background:#f7d060;box-shadow:0 0 6px #f7d060;animation-delay:.14s;}
.td:nth-child(3){background:#fbbf24;box-shadow:0 0 6px #fbbf24;animation-delay:.28s;}
@keyframes tdJ{0%,60%,100%{transform:translateY(0);opacity:.28;}30%{transform:translateY(-7px);opacity:1;}}
.msg-link{color:#f7d060;text-decoration:underline;text-underline-offset:3px;text-decoration-color:rgba(247,208,96,.3);word-break:break-all;cursor:pointer;transition:.15s;}
.msg-link:hover{color:#fbbf24;}
.scroll-fab{position:absolute;bottom:150px;right:14px;z-index:20;width:34px;height:34px;border-radius:10px;border:none;cursor:pointer;background:rgba(228,172,40,.12);border:1px solid rgba(228,172,40,.28);color:#f0c840;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(228,172,40,.14);opacity:0;transform:translateY(10px) scale(.8);transition:.24s cubic-bezier(.34,1.56,.64,1);pointer-events:none;}
.scroll-fab svg{width:15px;height:15px;}
.scroll-fab.show{opacity:1;transform:translateY(0) scale(1);pointer-events:auto;}
.scroll-fab:hover{transform:scale(1.09);}
.quick-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;padding:10px 14px 8px;flex-shrink:0;border-top:1px solid rgba(228,172,40,.07);background:rgba(0,0,0,.35);}
.q-btn{display:flex;align-items:center;gap:6px;padding:7px 8px;border-radius:8px;border:none;cursor:pointer;background:rgba(228,172,40,.05);border:1px solid rgba(228,172,40,.11);color:rgba(240,200,64,.65);font-size:10.5px;font-weight:500;font-family:'Sora','Noto Sans Myanmar',sans-serif;transition:.16s cubic-bezier(.34,1.56,.64,1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.q-btn svg{width:11px;height:11px;flex-shrink:0;color:#e4ac28;}
.q-btn:hover{background:rgba(228,172,40,.13);border-color:rgba(228,172,40,.28);color:#f0c840;transform:translateY(-1px);box-shadow:0 3px 12px rgba(228,172,40,.10);}
.q-btn:active{transform:translateY(1px);}
footer{display:flex;align-items:center;gap:10px;padding:10px 16px 16px;flex-shrink:0;border-top:1px solid rgba(228,172,40,.08);background:rgba(0,0,0,.55);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);}
.input-field-wrap{flex:1;position:relative;border-bottom:2px solid rgba(228,172,40,.18);transition:border-color .3s;}
.input-field-wrap:focus-within{border-color:rgba(228,172,40,.60);}
.input-field-wrap::after{content:'';position:absolute;bottom:-2px;left:0;right:100%;height:2px;background:#e4ac28;box-shadow:0 0 8px rgba(228,172,40,.5);transition:right .35s ease;}
.input-field-wrap:focus-within::after{right:0;}
#userInput{width:100%;padding:10px 4px;border:none;outline:none;background:transparent;font-size:14px;color:#fef9ee;letter-spacing:.01em;caret-color:#e4ac28;font-family:'Sora','Noto Sans Myanmar',sans-serif;}
#userInput::placeholder{color:rgba(255,255,255,.22);}
.send-btn{width:44px;height:44px;border-radius:12px;border:none;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(145deg,#c98f18,#e4ac28,#f7d060);box-shadow:0 0 16px rgba(228,172,40,.28),0 4px 10px rgba(0,0,0,.4);transition:.18s cubic-bezier(.34,1.56,.64,1);position:relative;overflow:hidden;}
.send-btn svg{width:18px;height:18px;color:#050410;position:relative;z-index:1;}
.send-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(115deg,transparent 35%,rgba(255,255,255,.22) 50%,transparent 65%);opacity:0;transition:.2s;}
.send-btn:hover{transform:scale(1.07);box-shadow:0 0 24px rgba(228,172,40,.44),0 4px 14px rgba(0,0,0,.4);}
.send-btn:hover::before{opacity:1;}
.send-btn:active{transform:scale(.92);}
.send-btn:disabled{opacity:.3;cursor:not-allowed;transform:none;box-shadow:none;background:rgba(255,255,255,.07);}
#particleCanvas{position:fixed;inset:0;pointer-events:none;z-index:9999;}
@media(max-width:480px){
  .shell{border:none;max-width:100%;}
  #adminPanel{max-width:100%;}
}
